#include <stdio.h>
void array(int arr[],int n);
void sort (int arr[],int n);
int arr[]={64,34,25,12,22,11,90} ;
int n=sizeof(arr) /sizeof(arr[0]);

int main() {
    printf("original array:");
    array (arr,n);
     sort (arr,n);
 printf("sorted array :");
 array (arr,n);
    return 0;
}
    void sort(int arr[],int n)
    {
        for (int i=0;i<n;i++)
        {
          for (int j=0;j<n-i-1;j++)
          {
             if (arr[j]>arr[j+1])
             {
                 int x=arr[j];
                 arr[j]=arr[j+1];
                 arr[j+1]=x;
                 
             }
          }
        }
    }
    void array(int arr[],int n)
    {
        for (int i=0;i<n-1;i++)
        {
            printf("%d%s",arr[i],(i==n-1)?"":",");
        }
        printf("\n");
    }
