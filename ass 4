#include <stdio.h>

int main()
{
   
    int size = 0;
    printf ("Enter the size of the pyramid : ");
    scanf("%d",&size);
    
    for( int i = 0; i < size; i ++){
        for(int j = 0 ; j < 2 * ( size - i - 1);j++){
        printf(" ");
        }
        
        for (int x = 0; x < 2 * i + 1;x++ ){printf("* ");}
        
        printf("\n");
        
    }

    return 0;
}
